---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const {
  title = "Roots of Tomorrow",
  description = "A youth-led 501(c)(3) nonprofit restoring native forests across Northeast Ohio.",
  seamlessFooter = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/png" href="/rootslogo.png" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-canopy focus:px-4 focus:py-2 focus:text-paper">Skip to content</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer seamless={seamlessFooter} />
  </body>
</html>
