---
const links = [
  { href: "/", label: "Home" },
  { href: "/get-involved", label: "Get Involved" },
  { href: "/contact", label: "Contact" },
];
const path = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-canopy/10 bg-paper/70 shadow-sm backdrop-blur-xl">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-3">
    <a href="/" class="group flex items-center gap-2 font-display text-xl font-600 text-canopy sm:gap-3 sm:text-2xl">
      <img src="/rootslogo.png" alt="Roots of Tomorrow logo" width="52" height="52" class="h-10 w-10 rounded-full drop-shadow-sm transition-transform duration-200 group-hover:scale-105 sm:h-13 sm:w-13" />
      Roots of Tomorrow
    </a>

    <div class="hidden items-center gap-8 md:flex">
      {links.map((l) => (
        <a
          href={l.href}
          class={`font-display text-base font-500 tracking-wide transition-colors hover:text-leaf ${
            path === l.href ? "text-canopy" : "text-soil/60"
          }`}
        >
          {l.label}
        </a>
      ))}
      <a
        href="/donate"
        class="rounded-full bg-canopy px-6 py-2 font-display text-base font-600 text-paper shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:bg-leaf hover:shadow-md"
      >
        Donate
      </a>
    </div>

    <details class="md:hidden">
      <summary class="cursor-pointer list-none rounded-lg p-2 text-canopy" aria-label="Menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M4 6h16M4 12h16M4 18h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </summary>
      <div class="absolute right-6 mt-2 flex w-48 flex-col gap-1 rounded-xl border border-cream bg-paper p-2 shadow-lg">
        {links.map((l) => (
          <a href={l.href} class="rounded-lg px-3 py-2 font-display text-sm text-soil/80 hover:bg-cream">{l.label}</a>
        ))}
        <a href="/donate" class="mt-1 rounded-lg bg-canopy px-3 py-2 text-center font-display text-sm font-600 text-paper">Donate</a>
      </div>
    </details>
  </nav>
</header>
