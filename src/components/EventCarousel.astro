---
// Auto-scrolling, infinitely looping strip of past-event photos.
// Images are listed in order (1 first, 7 last) and the list is duplicated once
// so the track can translate by exactly -50% for a seamless CSS-only loop —
// no JavaScript shipped. Each image carries its own right margin (rather than a
// flex `gap`) so the halfway point lines up exactly with the start of the repeat.
const images = [
  "/images/events/event1.png",
  "/images/events/event2.png",
  "/images/events/event3.jpg",
  "/images/events/event4.png",
  "/images/events/event5.png",
  "/images/events/event6.png",
  "/images/events/event7.jpg",
];
const track = [...images, ...images];
---

<section class="mx-auto max-w-6xl px-6 pt-20">
  <p class="text-base font-600 uppercase tracking-[0.2em] text-moss sm:text-lg">Past Events</p>
  <h2 class="mt-3 font-display text-4xl font-600 leading-tight text-canopy sm:text-5xl">
    Where we've put down roots.
  </h2>

  <div class="carousel mt-8 overflow-hidden">
    <div class="track flex w-max">
      {track.map((src, i) => (
        <img
          src={src}
          alt={i < images.length ? "Roots of Tomorrow planting event" : ""}
          aria-hidden={i >= images.length ? "true" : undefined}
          class="mr-6 h-64 w-56 flex-none rounded-2xl object-cover shadow-md ring-1 ring-canopy/10 sm:h-80 sm:w-80"
        />
      ))}
    </div>
  </div>
</section>

<style>
  /* Soft fade at both edges so photos ease in and out of view. */
  .carousel {
    -webkit-mask-image: linear-gradient(to right, transparent, #000 6%, #000 94%, transparent);
    mask-image: linear-gradient(to right, transparent, #000 6%, #000 94%, transparent);
  }
  .track {
    animation: event-scroll 38s linear infinite;
    will-change: transform;
  }
  /* Pause when a visitor hovers so they can look at a photo. */
  .carousel:hover .track {
    animation-play-state: paused;
  }
  @keyframes event-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }
  /* Respect users who ask for reduced motion. */
  @media (prefers-reduced-motion: reduce) {
    .track {
      animation: none;
    }
  }
</style>
