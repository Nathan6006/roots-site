---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Thank you | Roots of Tomorrow" description="Thanks for getting in touch with Roots of Tomorrow.">
  <section class="rise-in mx-auto flex min-h-[60vh] max-w-2xl flex-col items-center justify-center px-6 py-24 text-center">
    <p class="text-sm font-600 uppercase tracking-[0.2em] text-moss">Message sent</p>
    <h1 class="mt-3 font-display text-5xl font-600 leading-tight text-canopy sm:text-6xl">
      Thanks for reaching out.
    </h1>
    <p class="mt-6 max-w-xl text-lg leading-relaxed text-soil/75">
      Your message is in our inbox. We read every one and will get back to you
      as soon as we can.
    </p>
    <div class="mt-10 flex flex-wrap justify-center gap-4">
      <a href="/" class="rounded-full bg-canopy px-8 py-3.5 text-base font-600 text-paper shadow-md transition-all duration-200 hover:-translate-y-0.5 hover:bg-leaf hover:shadow-lg">
        Back to home
      </a>
      <a href="/get-involved" class="rounded-full border border-canopy px-8 py-3.5 text-base font-600 text-canopy transition-all duration-200 hover:-translate-y-0.5 hover:bg-canopy hover:text-paper">
        Get involved
      </a>
    </div>
  </section>
</Layout>
